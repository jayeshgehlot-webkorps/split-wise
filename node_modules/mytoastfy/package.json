{
  "name": "mytoastfy",
  "version": "1.0.0",
  "description": "A lightweight and modern toast notification library",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "toast",
    "notification",
    "typescript",
    "javascript",
    "ui"
  ],
  "author": "Raghvendra Pratap Singh",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/raghvendrasingh-webkorps/mytoastfy.git"
  },
  "homepage": "https://github.com/raghvendrasingh-webkorps/mytoastfy#readme",
  "bugs": {
    "url": "https://github.com/raghvendrasingh-webkorps/mytoastfy/issues"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
